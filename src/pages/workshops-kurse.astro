---
import BaseLayout from '@layouts/BaseLayout.astro';
import WorkshopsHero from '@organisms/WorkshopsHero.astro';
import WorkshopsCalendar from '@organisms/WorkshopsCalendar.astro';
import EventCard from '@molecules/EventCard.astro';
import FeaturedTestimonial from '@organisms/FeaturedTestimonial.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

const pills = [
  { label: 'Alle', href: '#' },
  { label: 'Monats-Workshops', href: '#', active: true },
  { label: 'Systemisches Aufstellen', href: '#' },
  { label: 'Hypnose', href: '#' },
  { label: 'Numerologie', href: '#' },
  { label: 'Infoanlässe', href: '#' },
];

/* Calendar: a 30-day month whose 1st falls on Saturday (column index 5). */
const calendarEvents = [
  { day: 5, label: 'Im Rhythmus des Sommers', color: 'gold' as const, href: '/kurs/nummerologie-august' },
  { day: 12, label: 'Offener Aufstellungsabend', color: 'raspberry' as const, href: '/kurs/nummerologie-august' },
  { day: 19, label: 'Hypnose-Schnupperkurs', color: 'lavender' as const, href: '/kurs/nummerologie-august' },
  { day: 25, label: 'Infoanlass Systemische Ausbildung', color: 'fire' as const, href: '/kurs/nummerologie-august' },
];

const upcoming = [
  {
    image: '/images/placeholder/Placeholder-12.jpg',
    eyebrow: 'Systemisches Aufstellen | 28.6.2026 18:00',
    title: 'Lorem ipsum dolor sit amet',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
    price: '120 CHF',
    duration: '90 Min. | Online',
    ctaHref: '/kurs/nummerologie-august',
  },
  {
    image: '/images/placeholder/Placeholder-14.jpg',
    eyebrow: 'Systemisches Aufstellen | 28.6.2026 18:00',
    title: 'Lorem ipsum dolor sit amet',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
    price: '120 CHF',
    duration: '90 Min. | Online',
    ctaHref: '/kurs/nummerologie-august',
  },
  {
    image: '/images/placeholder/Placeholder-13.jpg',
    eyebrow: 'Systemisches Aufstellen | 28.6.2026 18:00',
    title: 'Lorem ipsum dolor sit amet',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
    price: 'Kostenlos :)',
    duration: '90 Min. | Online',
    ctaHref: '/kurs/nummerologie-august',
  },
];

const testimonials = [
  { quote: '"Ich bin wegen eines Numerologie-Abends gekommen — und drei Monate später habe ich mich für Level 1 angemeldet. Es hat sich alles gefügt."', name: 'Maria S.' },
  { quote: '"Der Monatsworkshop im März hat mir mehr gebracht als ein Jahr Therapie. Ich habe endlich verstanden wo mein Muster herkommt."', name: 'Maria S.' },
  { quote: '"Der Monatsworkshop im März hat mir mehr gebracht als ein Jahr Therapie. Ich habe endlich verstanden wo mein Muster herkommt."', name: 'Maria S.' },
  { quote: '"Axels Art Numerologie zu erklären — ohne Esoterik-Kitsch, direkt und präzise — hat mich vollständig überzeugt. Ich komme immer wieder."', name: 'Maria S.' },
];

const faqItems = [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für die Monats-Workshops?', answer: 'Nein. Die Monats-Workshops sind so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du wählst deinen Workshop im Kalender, klickst auf «Mehr erfahren» und meldest dich direkt an. Bei Fragen erreichst du uns jederzeit.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Workshops sind in der Regel keine kassenpflichtige Leistung. Manche Zusatzversicherungen unterstützen Bildungsangebote — frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Viele Workshops bieten wir online oder hybrid an — du siehst das Format jeweils direkt beim Termin im Kalender.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];
---

<BaseLayout
  title="Workshops & Kurse | VitaLunaris"
  description="Tauche ein in die Systeme der Seele mit Theres und Axel — Monats-Workshops, systemisches Aufstellen, Hypnose und Numerologie. Kalender & Übersicht aller Termine."
  currentPath="/workshops-kurse"
>
  <WorkshopsHero
    logo="/logo/logo-compact.svg"
    eyebrow="Workshops & Kurse"
    title={`Tauche ein in die<br /><em>Systeme der Seele</em> mit<br />Theres und Axel`}
    subtitle="Ob du deine Praxis erweitern oder einfach etwas Neues entdecken willst — hier ist der Raum für deine Entfaltung."
    pills={pills}
    workshopTitle="Monats-Workshops"
    workshopDescription="Jeden Monat ein anderes Thema — ausgerichtet am Rhythmus der Jahreszeiten und dem was gerade trägt. Für Einsteiger:innen und für alle die neues beschnuppern möchten."
  >
    <WorkshopsCalendar slot="calendar" daysInMonth={30} firstWeekday={5} events={calendarEvents} />
  </WorkshopsHero>

  {/* ===================== Nächste Kurse und Workshops ===================== */}
  <section class="upcoming">
    <div class="upcoming__inner">
      <Heading level={2} variant="h1" class="upcoming__title">Nächste Kurse und Workshops:</Heading>
      <div class="upcoming__grid">
        {upcoming.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== Testimonials ===================== */}
  <section class="quotes">
    <div class="quotes__grid">
      {testimonials.map((t) => (
        <article class="quote-card">
          <p class="quote-card__text">{t.quote}</p>
          <p class="quote-card__name">{t.name}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ===================== Tiefes Wissen — lavender ===================== */}
  <section class="deep">
    <div class="deep__inner">
      <div class="deep__art" aria-hidden="true">
        <img src="/images/ebene/Ebene_2-12.svg" alt="" class="deep__art-img" loading="lazy" decoding="async" />
      </div>
      <div class="deep__content">
        <Heading level={2} variant="h1" class="deep__title">Tiefes Wissen, das nicht nur erklärt wird</Heading>
        <Text size="p1" class="deep__body">VitaLunaris-Workshops sind kein Frontalunterricht. Sie sind Räume, in denen du etwas erlebst — und dadurch verstehst, was kein Buch erklären kann.</Text>
        <Text size="p1" class="deep__body">Ob du zum ersten Mal mit systemischer Arbeit in Berührung kommst oder deine Praxis vertiefen willst: hier findest du Formate, die wirklich tragen.</Text>
      </div>
    </div>
  </section>

  {/* ===================== Theresia & Axel Jansen ===================== */}
  <FeaturedTestimonial
    name={`Theresia &<br /><em>Axel Jansen</em>`}
    role=""
    quote={`Theresia Jansen begleitet seit über 30 Jahren Menschen in systemischer Arbeit und Heilkunde. In ihren Workshops verbindet sie Aufstellungen, EFT, Nervensystem-Arbeit und Heilkunde zu einem Erfahrungsraum der seinesgleichen sucht.<br /><br />Axel Jansen bringt Hypnose und Numerologie in Workshops ein, die gleichermassen präzise wie zugänglich sind. Zahlenmagie ohne Kitsch, Hypnose ohne Bühnentricks.<br /><br />Zusammen bieten Theres und Axel ein Spektrum, das in dieser Form in der Deutschschweiz einzigartig ist.`}
    image="/images/placeholder/placeholder-4.jpg"
    imageSide="right"
    ctaText="Mehr über uns"
    ctaHref="/ueber-uns"
  />

  {/* ===================== FAQ (dark) ===================== */}
  <Faq theme="dark" title="FAQ" items={faqItems} />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title="Impulse für deine<br />Seele"
    body="Unser Newsletter ist kein gewöhnlicher Newsletter: Kurse, Geschichten, Zahlenmagie von Axel und die energetische Schwingung und Theresia. Humorvoll. Sinnvoll. Manchmal beides gleichzeitig. Neue Blicktermine, Episoden und Einblicke aus der Praxis direkt in deiner Inbox."
    placeholder="E-mail Adresse"
    submitText="Anmelden"
  />
</BaseLayout>

<style>
  /* ============================================================
     UPCOMING — "Nächste Kurse und Workshops:" (3 event cards)
     ============================================================ */
  .upcoming { background: var(--c-spring-wood); padding: 40px 20px 60px; }
  @media (min-width: 768px)  { .upcoming { padding: 40px 32px 80px; } }
  @media (min-width: 1280px) { .upcoming { padding: 40px 60px 90px; } }
  @media (min-width: 1920px) { .upcoming { padding: 40px 90px 120px; } }

  .upcoming__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }
  @media (min-width: 1920px) { .upcoming__inner { gap: 64px; } }

  .upcoming__title { color: var(--c-cherrywood); text-align: center; margin: 0; }

  .upcoming__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .upcoming__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .upcoming__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

  /* ============================================================
     QUOTES — testimonial cards (quote + name)
     ============================================================ */
  .quotes { background: var(--c-spring-wood); padding: 0 20px 60px; }
  @media (min-width: 768px)  { .quotes { padding: 0 32px 80px; } }
  @media (min-width: 1280px) { .quotes { padding: 0 60px 90px; } }
  @media (min-width: 1920px) { .quotes { padding: 0 90px 120px; } }

  .quotes__grid {
    max-width: 1740px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px)  { .quotes__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .quotes__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .quote-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: 16.67px;
    padding: 24px;
    height: 100%;
  }
  @media (min-width: 1280px) { .quote-card { border-radius: 20px; padding: 32px; gap: 24px; } }

  .quote-card__text {
    margin: 0;
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    flex-grow: 1;
  }
  .quote-card__name {
    margin: 0;
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p2-size);
    line-height: 1.5;
    opacity: 0.8;
  }

  /* ============================================================
     DEEP — "Tiefes Wissen, das nicht nur erklärt wird" (lavender)
     ============================================================ */
  .deep { background: var(--c-lavender); color: var(--c-white); padding: 64px 20px; overflow: hidden; }
  @media (min-width: 768px)  { .deep { padding: 96px 32px; } }
  @media (min-width: 1280px) { .deep { padding: 120px 60px; } }
  @media (min-width: 1920px) { .deep { padding: 150px 90px; } }

  .deep__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1024px) {
    .deep__inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 80px; }
  }
  @media (min-width: 1920px) { .deep__inner { gap: 160px; } }

  /* Decorative brand graphic */
  .deep__art {
    flex: 0 0 auto;
    width: 240px;
    height: 240px;
  }
  @media (min-width: 1280px) { .deep__art { width: 320px; height: 320px; } }
  @media (min-width: 1920px) { .deep__art { width: 380px; height: 380px; } }
  .deep__art-img { width: 100%; height: 100%; object-fit: contain; display: block; }

  .deep__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    max-width: 760px;
  }
  @media (min-width: 1024px) { .deep__content { gap: 32px; } }

  .deep__title {
    color: var(--c-white);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .deep__body { color: var(--c-white); font-size: var(--p1-size); line-height: 1.5; }
</style>
