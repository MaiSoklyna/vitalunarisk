    eyebrow: 'Systemisches Aufstellen | 28.6.2026 18:00',
    title: 'Lorem ipsum dolor sit amet',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
    price: 'Kostenlos :)',
    duration: '90 Min. | Online',
    ctaHref: '/kurs/nummerologie-august',
  },
];

const faqItems = [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für den Kurs?', answer: 'Nein. Der Kurs ist so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du klickst auf «Jetzt anmelden», füllst das kurze Formular aus und erhältst alle Infos sowie den Zoom-Link per E-Mail.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Workshops sind in der Regel keine kassenpflichtige Leistung. Manche Zusatzversicherungen unterstützen Bildungsangebote — frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Dieser Kurs findet online via Zoom statt — den Link bekommst du nach der Anmeldung per E-Mail.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];
---

<BaseLayout
  title="Aktueller Monatsworkshop | VitaLunaris"
  description="Aktueller Monatsworkshop — Termine, Details und Anmeldung."
  currentPath="/workshops-kurse/aktueller-monatsworkshop"
>
  <CourseHero
    categoryMeta="MONATS-WORKSHOP | August | 12.8.2026"
    durationMeta="12.8.2026 16:30 Uhr | 120 Min. | Online  | Max. 9 Teilnehmer" 
    title="EIch bin der Titel <br /> des Kurses"
    description="Im August widmen wir uns ganz...odio cras proin proin sit quis fringilla aliquet. Consectetur elementum viverra egestas egestas nulla ullamcorper varius quam."
    price="Kostenlos :)"
    ctaText="Jetzt anmelden"
    ctaHref="/kontakt"
    image="/images/placeholder/Placeholder-12.jpg"
  />

  <InfoCardsRow cards={infoCards} />

  {/* ===================== Was wir anschauen — lavender ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image="/images/placeholder/placeholder-3.jpg"
    imageAlt=""
    eyebrow="Was wir anschauen"
    title="Lorem ipsum dolor sit amet"
    body="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur."
  />

  {/* ===================== Was Menschen zu unseren Kursen sagen ===================== */}
  <TestimonialsBlock
    title="Was Menschen zu unseren Kursen sagen"
    testimonials={testimonials}
  />

  {/* ===================== Theresia & Axel Jansen — gold ===================== */}
  <section class="about">
    <div class="about__inner">
      <div class="about__content">
        <Heading level={2} variant="h1" class="about__name">Theresia &<br /><em>Axel Jansen</em></Heading>
        <Text size="p1" class="about__body">
          Theresia Jansen begleitet seit über 30 Jahren Menschen in systemischer Arbeit und Heilkunde. In ihren Workshops verbindet sie Aufstellungen, EFT, Nervensystem-Arbeit und Heilkunde zu einem Erfahrungsraum der seinesgleichen sucht.
        </Text>
        <Text size="p1" class="about__body">
          Axel Jansen bringt Hypnose und Numerologie in Workshops ein, die gleichermassen präzise wie zugänglich sind. Zahlenmagie ohne Kitsch, Hypnose ohne Bühnentricks. Zusammen bieten Theres und Axel ein Spektrum, das in dieser Form in der Deutschschweiz einzigartig ist.
        </Text>
        <div class="about__cta">
          <Button href="/ueber-uns" variant="primary" size="lg">Mehr über uns</Button>
        </div>
      </div>
      <div class="about__media">
        <img src="/images/placeholder/placeholder-4.jpg" alt="Theresia & Axel Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== Weitere Kurse und Workshops — dark ===================== */}
  <section class="further">
    <div class="further__inner">
      <Heading level={2} variant="h1" class="further__title">Weitere Kurse und Workshops:</Heading>
      <div class="further__grid">
        {furtherCourses.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />
</BaseLayout>

<style>
  /* ============================================================
     ABOUT — "Theresia & Axel Jansen" (Pale Gold, text left / image right)
     ============================================================ */
  .about { background: var(--c-spring-wood); padding: 60px 20px; }
  @media (min-width: 768px)  { .about { padding: 80px 32px; } }
  @media (min-width: 1280px) { .about { padding: 90px 60px; } }
  @media (min-width: 1920px) { .about { padding: 90px; } }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .about__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .about__inner { gap: 100px; } }

  .about__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: 16.67px;
    background: rgba(96, 29, 29, 0.06);
    aspect-ratio: 4 / 5;
    order: -1;
  }
  @media (min-width: 1024px) { .about__media { width: 46%; border-radius: 20px; order: 0; } }
  @media (min-width: 1920px) { .about__media { width: 711px; border-radius: 25px; aspect-ratio: 711 / 826; } }
  .about__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .about__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (min-width: 1024px) { .about__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about__content { gap: 32px; max-width: 813px; } }

  .about__name {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about__name :global(em) { font-style: italic; }
  .about__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }
  .about__cta { margin-top: 8px; }

  /* ============================================================
     FURTHER — "Weitere Kurse und Workshops:" (Cherrywood, 3 cards)
     ============================================================ */
  .further { background: var(--c-cherrywood); padding: 60px 20px; }
  @media (min-width: 768px)  { .further { padding: 80px 32px; } }
  @media (min-width: 1280px) { .further { padding: 90px 60px; } }
  @media (min-width: 1920px) { .further { padding: 120px 90px; } }

  .further__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1920px) { .further__inner { gap: 64px; } }

  .further__title {
    color: var(--c-spring-wood);
    text-align: center;
    margin: 0;
    max-width: 862px;
  }

  .further__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .further__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .further__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
</style>
