  { quote: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.', name: 'Maria S.' },
];

const furtherCourses = [
  {
    image: '/images/placeholder/Placeholder-12.jpg',
    eyebrow: 'MONATS-WORKSHOP | August | 12.8.2026',
    title: 'Ich bin der Titel des Kurses',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
    price: '120 CHF',
    duration: '90 Min. | Online',
    ctaHref: '/kurs/nummerologie-august',
  },
  {
    image: '/images/placeholder/Placeholder-14.jpg',
    eyebrow: 'Systemisches Aufstellen | 28.6.2026 18:00',
    title: 'Lorem ipsum dolor sit amet',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam nostrud exercitation.',
