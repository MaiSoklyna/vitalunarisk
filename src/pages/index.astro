---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@organisms/Hero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import OfferCardsBlock from '@organisms/OfferCardsBlock.astro';
import ProcessSteps from '@organisms/ProcessSteps.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import ClaimBlock from '@organisms/ClaimBlock.astro';
import FeaturedTestimonial from '@organisms/FeaturedTestimonial.astro';
import DarkCtaBlock from '@organisms/DarkCtaBlock.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';

const offers = [
  {
    icon: '/images/ebene/Ebene_2-3.svg',
    title: 'Ich will Systemisches Aufstellen lernen',
    description: 'Du willst systemisches Aufstellen nicht nur erleben, sondern auch selber anwenden oder sogar weitergeben. Die Ausbildung zum Systemic Soulcoach gibt dir das Handwerk und die Tiefe dafür.',
    ctaText: 'Zu den Ausbildungen →',
    ctaHref: '/ausbildung',
  },
  {
    icon: '/images/ebene/Ebene_2-8.svg',
    title: 'Ich will meine Praxis vertiefen oder Neues lernen',
    description: 'Aus unserem Jahrzehntelangen Erfahrungsschatz geben wir unser Wissen weiter. Wir bieten Weiterbildungen und Kurse in verschiedenen systemischen Bereichen an: Aufstellen, Hypnose, Numerologie, EFT und vieles mehr.',
    ctaText: 'Zu den Workshops & Kursen →',
    ctaHref: '/workshops',
  },
  {
    icon: '/images/ebene/Ebene_2-6.svg',
    title: 'Ich suche eine Veränderung in meinem Leben',
    description: 'Etwas in deinem Leben fühlt sich fest an — eine Beziehung, eine Entscheidung, ein Muster, das sich wiederholt. Es gibt verschiedene Wege, das sichtbar und veränderbar zu machen.',
    ctaText: 'Unsere Praxisangebote →',
    ctaHref: '/praxisangebote',
  },
];

const steps = [
  {
    title: 'Erstgespräch',
    description: 'Wir lernen uns kennen, du erzählst, was dich bewegt — und wir klären, ob die Chemie stimmt.',
    color: 'gold' as const,
  },
  {
    title: 'Tiefenarbeit',
    description: 'In ausgewählten Sitzungen gehen wir gemeinsam dorthin, wo sich Bewegung zeigt — geschützt und klar.',
    color: 'aurora' as const,
  },
  {
    title: 'Transformation',
    description: 'Was sich gezeigt hat, darf sich verwandeln. Wir geben dem Neuen Form, ohne das Alte zu verleugnen.',
    color: 'raspberry' as const,
  },
  {
    title: 'Integration',
    description: 'Das Erkannte ins Leben weben — mit konkreten Schritten, Ritualen und einer tragenden Praxis.',
    color: 'purple' as const,
  },
];

const testimonials = [
  {
    icon: '/images/ebene/Ebene_2-4.svg',
    quote: 'Bei VitaLunaris habe ich erfahren, wie kraftvoll es ist, sich selbst wirklich zuzuhören. Eine Begleitung, die berührt.',
    name: 'Maria S.',
  },
  {
    icon: '/images/ebene/Ebene_2-5.svg',
    quote: 'Klar, präsent und ohne Esoterik-Floskeln. Genau das, was ich gebraucht habe, um durch eine schwierige Phase zu gehen.',
    name: 'Thomas K.',
  },
  {
    icon: '/images/ebene/Ebene_2-6.svg',
    quote: 'Ein Raum, in dem ich endlich aufhören durfte, stark zu sein — und dadurch wieder Kraft gefunden habe.',
    name: 'Claudia R.',
  },
  {
    icon: '/images/ebene/Ebene_2-7.svg',
    quote: 'Die Begleitung hat mein Verhältnis zu mir selbst verändert. Mehr Tiefe, mehr Freude, mehr Leben — wie versprochen.',
    name: 'Lena M.',
  },
];

const faqItems = [
  {
    question: 'Für wen ist VitaLunaris?',
    answer: 'Für Menschen, die spüren, dass etwas in Bewegung kommen will — und einen klaren, sicheren Rahmen suchen, um dorthin zu gehen. Ob in einer Lebensphase voller Fragen oder mitten in einer konkreten Veränderung.',
  },
  {
    question: 'Wie läuft eine erste Sitzung ab?',
    answer: 'Wir beginnen mit einem unverbindlichen Erstgespräch von 30 Minuten — online oder vor Ort. Du erzählst, was dich bewegt, und wir klären gemeinsam, ob die Chemie stimmt und welcher Weg passt.',
  },
  {
    question: 'Wie viele Sitzungen brauche ich?',
    answer: 'Das ist sehr individuell. Manche Menschen kommen für eine einzelne Sitzung mit einem klaren Anliegen, andere begleiten wir über Monate. Im Erstgespräch finden wir gemeinsam heraus, was zu dir passt.',
  },
  {
    question: 'Arbeitet ihr auch mit Paaren?',
    answer: 'Ja. Paarbegleitung ist ein eigener Schwerpunkt unserer Arbeit. Die Sitzungen folgen denselben Prinzipien — geschützter Raum, klare Sprache, Tiefe ohne Druck.',
  },
  {
    question: 'Werden die Kosten von der Krankenkasse übernommen?',
    answer: 'Wir sind keine Psychotherapeut:innen im medizinischen Sinn. Unsere Begleitung ist eine private Leistung und wird in der Regel nicht von der Krankenkasse gedeckt. Frag im Zweifelsfall deine Zusatzversicherung.',
  },
];
---

<BaseLayout
  title="VitaLunaris – Erforsche die Systeme der Seele"
  description="VitaLunaris in Zürich begleitet dich in Tiefenarbeit, Integration und Transformation — mit klarem Vorgehen und geschützten Räumen."
  currentPath="/"
>
  <Hero
    eyebrow="Willkommen bei VitaLunaris"
    title='Erforsche die<br class="hero__br--md" /> Systeme der .
    <br class="hero__br--md"/>Seele'
    subtitle="VitaLunaris ist die Praxis für systemisches Aufstellen, Heilkunde, Hypnose und Nummerologie. Gegründet und gelebt auf Jahrzehnten gelebter Erfahrung von Theresia und Axel Jansen."
    ctaText="Erstgespräch buchen"
    ctaHref="/kontakt"
    secondaryCtaText="Unsere Angebote"
    secondaryCtaHref="/angebot"
    image="/images/placeholder/Placeholder_1.jpg"
  />
  

  <OfferCardsBlock
    title="Wie können wir dir helfen?"
    offers={offers}
  />

  <NarrativeBlock
    tone="light"
    imageSide="left"
    image="/images/placeholder/Placeholder-6.jpg" 
    imageAlt=""
    title="Wissen, das nicht nur aus Büchern kommt."
    body="Systemisches Aufstellen macht sichtbar, was unter der Oberfläche wirkt. Muster in Familien, in Beziehungen, im eigenen Körper — sie lassen sich erkennen, verstehen und verändern. Theres Jansen arbeitet seit über 30 Jahren in der Heilkunde. Körperlich wie energetisch. Was sie lehrt und begleitet, hat sie selbst durchlebt, verfeinert und tausende Male in der Praxis bewährt. Das ist der Unterschied zwischen Wissen und Erfahrung."
  />

  <NarrativeBlock
    tone="purple"
    imageSide="right"
    image="/images/placeholder/placeholder-3.jpg"
    imageAlt=""
    mediaAspect="16 / 10"
    title={`”VitaLunaris ist kein Konzept — es ist ein Feld, in dem wir Raum für dich halten. Ein Raum, in dem Transformation geschehen<br />kann: sanft,&nbsp;ehrlich&nbsp;und&nbsp;tief.”`}
    body="Theresia & Axel Jansen · VitaLunaris"
  />

  <TestimonialsBlock
    eyebrow="Stimmen"
    title="Was Menschen sagen."
    testimonials={testimonials}
  />

  <ClaimBlock
    title="Mehr Tiefe. Mehr Freude. Mehr Leben."
    body="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Tiefenpsychologisch fundiert · Systemisch & körperorientiert · Für Einzelpersonen, Paare & Familien."
    image="/images/ebene/Ebene_2-7.svg"
    ctaText="Erstgespräch buchen"
    ctaHref="/kontakt"
  />

  <FeaturedTestimonial
    eyebrow="Klient:innen-Stimme"
    name="Theresia & Axel<br />Jansen"
    role="Klient:innen seit 2024"
    quote="Diese Begleitung hat unser Verhältnis zueinander, zu uns selbst und zu dem, was wirklich zählt, neu geordnet. Wir kamen mit Fragen — und gingen mit Klarheit."
    image="/images/placeholder/placeholder-4.jpg"
    imageSide="right"
  />

  <DarkCtaBlock
    eyebrow="Bereit?"
    title="Bereit, tiefer<br />zu gehen?"
    body="Wenn du das Gefühl hast, dass jetzt der richtige Moment ist — komm in ein unverbindliches Erstgespräch. Wir klären gemeinsam, was du brauchst."
    ctaText="Erstgespräch buchen"
    ctaHref="/kontakt"
    backgroundImage="/images/placeholder/narrative-block-7.jpg"
  />

 

  <NewsletterBlock
    eyebrow="Newsletter"
    title="Impulse für deine<br />innere Reise."
    body="Einmal im Monat: Gedanken, Übungen und Einladungen — sorgfältig kuratiert, nie aufdringlich."
    placeholder="deine@email.ch"
    submitText="Abonnieren"
  />
</BaseLayout>
