---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="ovh">
  <div class="ovh__inner">
    {eyebrow && <Heading variant="eyebrow" class="ovh__eyebrow">{eyebrow}</Heading>}
    <Heading level={1} class="ovh__title"><Fragment set:html={title} /></Heading>
    {subtitle && <Text size="p1" class="ovh__subtitle">{subtitle}</Text>}
  </div>
</section>

<style>
  /* ============================================================
     OVERVIEW HERO — centered eyebrow + title + subtitle.
     Top padding clears the fixed Navigation. Responsive 360/768/1280/1920.
     ============================================================ */
  .ovh {
    background: var(--c-spring-wood);
    padding: 120px 20px 48px;
  }
  @media (min-width: 768px)  { .ovh { padding: 160px 32px 64px; } }
  @media (min-width: 1280px) { .ovh { padding: 170px 60px 72px; } }
  @media (min-width: 1920px) { .ovh { padding: 220px 90px 90px; } }

  .ovh__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    max-width: 1106px;
    margin: 0 auto;
  }
  @media (min-width: 1280px) { .ovh__inner { gap: 32px; } }
  @media (min-width: 1920px) { .ovh__inner { gap: 40px; max-width: 1280px; } }

  .ovh__eyebrow {
    display: block;
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    font-size: var(--eyebrow-size);
    line-height: 1.2;
    letter-spacing: 0.08em;
  }

  .ovh__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }

  .ovh__subtitle {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    max-width: 880px;
  }
</style>
