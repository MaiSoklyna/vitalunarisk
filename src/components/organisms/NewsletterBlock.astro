---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  placeholder?: string;
  submitText?: string;
  action?: string;
  privacyText?: string;
}

const {
  eyebrow,
  title,
  body,
  placeholder = 'E-Mail Adresse',
  submitText = 'Anmelden',
  action = '#',
  privacyText,
} = Astro.props;
---

<section class="newsletter">
  <div class="newsletter__card max-w-layout">
    <img
      src="/images/ebene/Ebene_1 (4).svg"
      alt=""
      aria-hidden="true"
      class="newsletter__decor newsletter__decor--tl"
    />
    <img
      src="/images/ebene/Ebene_1 (6).svg"
      alt=""
      aria-hidden="true"
      class="newsletter__decor newsletter__decor--br"
    />

    <div class="newsletter__content">
      {eyebrow && <Heading variant="eyebrow" class="newsletter__eyebrow">{eyebrow}</Heading>}
      <Heading level={2} variant="h1" class="newsletter__title">
        <Fragment set:html={title} />
      </Heading>
      {body && <Text size="p1" class="newsletter__body">{body}</Text>}

      <form class="newsletter__form" action={action} method="POST" novalidate>
        <label for="newsletter-email" class="newsletter__label sr-only">E-Mail-Adresse</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          class="newsletter__input"
          placeholder={placeholder}
          required
          autocomplete="email"
        />
        <button type="submit" class="newsletter__submit">{submitText}</button>
      </form>

      {privacyText && <Text size="p3" class="newsletter__privacy">{privacyText}</Text>}
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: var(--c-spring-wood);
    padding: 40px 20px;
  }
  @media (min-width: 768px) { .newsletter { padding: 64px 32px; } }
  @media (min-width: 1280px) { .newsletter { padding: 90px 60px; } }

  .newsletter__card {
    position: relative;
    overflow: hidden;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: 25px;
    padding: 80px 24px;
    min-height: 480px;
    width: 100%;
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (min-width: 768px) { .newsletter__card { padding: 120px 48px; min-height: 640px; } }
  @media (min-width: 1280px) { .newsletter__card { padding: 180px 60px; min-height: 901px; } }

  .newsletter__decor {
    position: absolute;
    pointer-events: none;
    user-select: none;
    height: auto;
    opacity: 1;
  }

  /* Figma: 935 × 634 at left -297, top -95.5 inside a 1740 × 901 card */
  .newsletter__decor--tl {
    width: 53.74%;
    top: -10.6%;
    left: -17.07%;
  }

  /* Figma: 865 × 577 at left 1084, top 513.5 inside a 1740 × 901 card */
  .newsletter__decor--br {
    width: 49.71%;
    bottom: -21.03%;
    right: -12.01%;
  }

  .newsletter__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    max-width: 856px;
    width: 100%;
  }
  @media (min-width: 1024px) { .newsletter__content { gap: 40px; } }

  .newsletter__eyebrow { color: var(--c-cherrywood); opacity: 0.8; }

  .newsletter__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park TRIAL', serif;
    font-weight: 400;
    font-size: 44px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
  }
  @media (min-width: 768px) { .newsletter__title { font-size: 64px; } }
  @media (min-width: 1280px) { .newsletter__title { font-size: 90px; } }

  .newsletter__body {
    color: var(--c-cherrywood);
    font-family: 'ES Park TRIAL', serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.5;
    max-width: 720px;
  }
  @media (min-width: 768px) { .newsletter__body { font-size: 23px; } }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 706px;
  }
  @media (min-width: 640px) {
    .newsletter__form { flex-direction: row; align-items: center; gap: 16px; }
  }

  .newsletter__label.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .newsletter__input {
    flex-grow: 1;
    height: 61px;
    padding: 20px 30px;
    background: transparent;
    border: 0.8px solid var(--c-cherrywood);
    border-radius: 100px;
    color: var(--c-cherrywood);
    font-family: 'ES Park TRIAL', serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 21px;
    outline: none;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .newsletter__input::placeholder { color: var(--c-cherrywood); opacity: 0.5; }
  .newsletter__input:focus {
    background: rgba(96, 29, 29, 0.04);
    border-color: var(--c-cherrywood);
  }

  .newsletter__submit {
    flex-shrink: 0;
    height: 61px;
    padding: 20px 30px;
    background: var(--c-cherrywood);
    color: var(--c-spring-wood);
    border: 1.4px solid var(--c-cherrywood);
    border-radius: 100px;
    font-family: 'ES Park TRIAL', serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 21px;
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease, transform 200ms ease;
    white-space: nowrap;
  }
  @media (min-width: 640px) { .newsletter__submit { min-width: 139px; } }
  .newsletter__submit:hover { background: #4A1414; }
  .newsletter__submit:active { transform: scale(0.98); }

  .newsletter__privacy { color: var(--c-cherrywood); opacity: 0.6; margin-top: 4px; }
</style>
