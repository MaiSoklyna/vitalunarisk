---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

interface Props {
  categoryMeta: string;
  durationMeta: string;
  title: string;
  description?: string;
  price: string;
  ctaText?: string;
  ctaHref?: string;
  image: string;
  imageAlt?: string;
}

const {
  categoryMeta,
  durationMeta,
  title,
  description,
  price,
  ctaText = 'Jetzt buchen',
  ctaHref = '/kontakt',
  image,
  imageAlt = '',
} = Astro.props;
---

<section class="course-hero">
  <div class="course-hero__inner">
    <div class="course-hero__content">
      <Heading variant="eyebrow" class="course-hero__category">{categoryMeta}</Heading>
      <Heading level={1} class="course-hero__title">
        <Fragment set:html={title} />
      </Heading>
      {description && <Text size="p1" class="course-hero__desc">{description}</Text>}
      {durationMeta && <Text size="p2" class="course-hero__duration">{durationMeta}</Text>}
      <Heading level={3} class="course-hero__price">{price}</Heading>
      <div class="course-hero__cta">
        <Button href={ctaHref} variant="primary" size="lg">{ctaText}</Button>
      </div>
    </div>
    <div class="course-hero__media">
      <img src={image} alt={imageAlt} class="course-hero__image" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     COURSE HERO — responsive (360 / 768 / 1280 / 1920)
     ============================================================ */

  /* ----- SECTION (mirrors Hero — top padding clears the fixed nav) ----- */
  .course-hero { background: var(--c-spring-wood); padding: 72px 20px 64px; }
  @media (min-width: 768px)  { .course-hero { padding: 120px 32px 80px; } }
  @media (min-width: 1280px) { .course-hero { padding: 80px 60px 80px; } }
  @media (min-width: 1920px) { .course-hero { padding: 175px 90px 90px; } }

  /* ----- INNER ----- */
  .course-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  .course-hero__media   { order: 0; }   /* image above text on mobile/tablet */
  .course-hero__content { order: 1; }

  @media (min-width: 1024px) {
    .course-hero__inner { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 64px; }
    .course-hero__media   { order: 2; }  /* image right of text on desktop */
    .course-hero__content { order: 1; }
  }
  /* Desktop++ — horizontal flow, fixed 170px gap, image right of text */
  @media (min-width: 1920px) {
    .course-hero__inner {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
      align-items: center;
      gap: 170px;
      max-width: none;
      padding: 0;
    }
    .course-hero__content { order: 1; }
    .course-hero__media   { order: 2; }
  }

  /* ----- CONTENT ----- */
  .course-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 26.67px;
  }
  @media (min-width: 1920px) {
    .course-hero__content {
      gap: 40px;
      width: 813px;
      flex: 0 0 813px;
    }
  }

  /* ----- CATEGORY (eyebrow, full-width row) ----- */
  .course-hero__category {
    color: var(--c-cherrywood);
    align-self: stretch;
  }

  /* ----- DURATION (meta line below the description) ----- */
  .course-hero__duration {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p2-size);
    line-height: 1.4;
    color: var(--c-cherrywood);
    align-self: stretch;
  }

  /* ----- TITLE ----- */
  .course-hero__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    color: var(--c-cherrywood);
    margin: 0;
    align-self: stretch;
  }

  /* ----- DESCRIPTION ----- */
  .course-hero__desc {
    font-family: 'ES Park', serif;
    font-size: var(--p1-size);
    line-height: 1.5;
    color: var(--c-cherrywood);
    align-self: stretch;
  }

  /* ----- PRICE ----- */
  .course-hero__price {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }

  /* ----- MEDIA (mirrors Hero) ----- */
  .course-hero__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 25px;
    background: var(--c-pale-gold);
    width: 100%;
  }
  @media (min-width: 1024px) { .course-hero__media { aspect-ratio: 1 / 1; } }
  @media (min-width: 1920px) {
    .course-hero__media {
      width: 858px;
      height: 868px;
      aspect-ratio: auto;
      flex: 0 0 858px;
    }
  }

  /* ----- IMAGE ----- */
  .course-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
