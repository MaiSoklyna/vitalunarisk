---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import OfferCard from '@molecules/OfferCard.astro';

interface Offer {
  icon?: string;
  iconAlt?: string;
  title: string;
  description: string;
  price?: string;
  priceCaption?: string;
  ctaText?: string;
  ctaHref?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  offers: Offer[];
}

const { eyebrow, title, intro, offers } = Astro.props;
---

<section class="offer-block">
  <div class="offer-block__inner max-w-layout container-x">
    <header class="offer-block__header">
      {eyebrow && <Heading variant="eyebrow" class="offer-block__eyebrow">{eyebrow}</Heading>}
      <Heading level={2} variant="h1" class="offer-block__title">{title}</Heading>
      {intro && <Text size="p1" class="offer-block__intro">{intro}</Text>}
    </header>

    <div class="offer-block__grid">
      {offers.map((o) => <OfferCard {...o} />)}
    </div>
  </div>
</section>

<style>
  .offer-block { background: var(--c-spring-wood); padding: 60px 20px; }
  @media (min-width: 768px)  { .offer-block { padding: 60px 32px; } }
  @media (min-width: 1024px) { .offer-block { padding: 80px 40px; } }
  @media (min-width: 1280px) { .offer-block { padding: 60px 0; } }
  @media (min-width: 1920px) { .offer-block { padding: 90px; } }

  /* Header — Figma spec: centered, gap 26.67px, H1 60/69 Cherrywood, P1 16/150 Cherrywood */
  .offer-block__header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 26.67px;
    margin: 0 auto 48px;
    width: 100%;
    max-width: 574.67px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .offer-block__header { padding-left: 40px; padding-right: 40px; max-width: 654.67px; }
  }
  /* Desktop+ (Figma): centered text block 862px wide, 64px gap down to the cards */
  @media (min-width: 1280px) {
    .offer-block__header { max-width: 862px; gap: 40px; margin-bottom: 64px; }
  }
  .offer-block__eyebrow {
    color: var(--c-cherrywood);
    text-align: center;
    align-self: stretch;
  }
  .offer-block__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    text-align: center;
    align-self: stretch;
    margin: 0;
  }
  .offer-block__intro {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    text-align: center;
    align-self: stretch;
  }

  .offer-block__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  /* minmax(0, 1fr) forces truly equal columns — plain 1fr lets a card with
     wider min-content (long word / button label) steal width from the others. */
  @media (min-width: 1024px) {
    .offer-block__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
  }
  /* Figma cards row: 3 × 558.67 + 2 × 32 gap = 1740px */
  @media (min-width: 1280px) { .offer-block__grid { gap: 32px; } }

  /* Desktop++ (Figma w=1920): full 1740px row — widen past the default 1490px
     layout cap and drop the container-x padding (block already pads 90px). */
  @media (min-width: 1920px) {
    .offer-block__inner { max-width: 1740px; padding-left: 0; padding-right: 0; }
  }
</style>
