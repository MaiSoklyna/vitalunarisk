---
type IconName = 'menu' | 'close' | 'arrow-right' | 'chevron-down';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  [key: string]: any;
}

const { name, size = 24, class: className = '', ...rest } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  {...rest}
>
  {name === 'menu' && (
    <>
      <line x1="4" y1="7" x2="20" y2="7" />
      <line x1="4" y1="12" x2="20" y2="12" />
      <line x1="4" y1="17" x2="20" y2="17" />
    </>
  )}
  {name === 'close' && (
    <>
      <line x1="6" y1="6" x2="18" y2="18" />
      <line x1="18" y1="6" x2="6" y2="18" />
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="13 6 19 12 13 18" />
    </>
  )}
  {name === 'chevron-down' && <polyline points="6 9 12 15 18 9" />}
</svg>
