---
type Tag = 'p' | 'span' | 'div' | 'label' | 'a' | 'li';
type Size = 'p1' | 'p2' | 'p3' | 'tag' | 'link';

interface Props {
  as?: Tag;
  size?: Size;
  href?: string;
  class?: string;
  [key: string]: any;
}

const { as = 'p', size = 'p1', href, class: className = '', ...rest } = Astro.props;
const Component = href ? 'a' : as;
const typeClass = `type-${size}`;
---

<Component class={`${typeClass} ${className}`} href={href} {...rest}><slot /></Component>
